# Copy to .env (gitignored) and fill in. Read by docker-compose.yml.

# On-demand ISR: backend pings this site webhook after a content save so the
# site refreshes immediately instead of waiting out its ISR window.
# URL  = the site's /api/revalidate (change to the VPS site address on deploy).
# SECRET must equal REVALIDATE_SECRET configured on the site.
SITE_REVALIDATE_URL=https://your-site-domain/api/revalidate
SITE_REVALIDATE_SECRET=change-me-shared-secret
